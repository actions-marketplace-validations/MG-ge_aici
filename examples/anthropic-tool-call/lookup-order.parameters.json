{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["order_id", "include_refunds"],
  "additionalProperties": false,
  "properties": {
    "order_id": {
      "type": "string",
      "pattern": "^[A-Z][0-9]+$"
    },
    "include_refunds": {
      "type": "boolean"
    }
  }
}
