{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["decision", "reason"],
  "additionalProperties": false,
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["approved", "rejected", "needs_review"]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
