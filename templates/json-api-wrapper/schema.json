{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["status", "data", "warnings"],
  "additionalProperties": false,
  "properties": {
    "status": {
      "enum": ["ok", "error"]
    },
    "data": {
      "type": "object"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
